# ===== Site =====
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ===== Analytics & Search Console (both optional) =====
# Google Analytics 4 measurement ID (G-XXXXXXXXXX). When unset, the GA
# script tag is omitted entirely.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Google Search Console verification token from the meta-tag method.
# Paste only the value of `content="..."` (no quotes, no surrounding tag).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ===== Supabase (https://supabase.com) =====
# Northeast Asia (Seoul / ap-northeast-2) project. See
# docs/runbooks/supabase-setup.md for setup steps.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — never expose to the client. Used by future server actions
# that need to bypass RLS (e.g. admin moderation endpoints).
SUPABASE_SERVICE_ROLE_KEY=

# ===== Sanity (https://sanity.io) — being phased out, see ADR-0004 =====
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01
# Read token (Viewer). Required only for draft/preview.
SANITY_API_READ_TOKEN=
# Webhook secret shared with Sanity -> GROQ webhook
SANITY_REVALIDATE_SECRET=
# Webhook secret for the SEPARATE syndication webhook (POST /api/syndicate).
# Kept distinct from SANITY_REVALIDATE_SECRET so it can be rotated or
# disabled independently. See docs/runbooks/sns-syndication.md.
SANITY_SYNDICATE_SECRET=

# ===== SNS auto-sync (all optional; fill per platform) =====
# X (Twitter) — Free tier: 1,500 posts/month
X_API_KEY=
X_API_KEY_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Instagram Graph API (requires FB Page + IG Business account)
IG_USER_ID=
IG_ACCESS_TOKEN=

# LINE Messaging API (LINE Notify EOL 2025-03-31)
LINE_CHANNEL_ACCESS_TOKEN=
LINE_TARGET_ID=

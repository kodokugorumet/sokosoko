# ===== Site =====
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ===== Analytics & Search Console (both optional) =====
# Google Analytics 4 measurement ID (G-XXXXXXXXXX). When unset, the GA
# script tag is omitted entirely.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Google Search Console verification token from the meta-tag method.
# Paste only the value of `content="..."` (no quotes, no surrounding tag).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ===== Supabase (https://supabase.com) =====
# Northeast Asia (Seoul / ap-northeast-2) project. See
# docs/runbooks/supabase-setup.md for setup steps.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — never expose to the client. Used by future server actions
# that need to bypass RLS (e.g. admin moderation endpoints).
SUPABASE_SERVICE_ROLE_KEY=

# ===== SNS auto-syndication (all optional) =====
# X (Twitter) — Free tier: 1,500 posts/month. OAuth 1.0a user-context
# 4-tuple. When all 4 are set, publishing a post from /admin/posts will
# automatically tweet the title + article URL. If any is missing,
# syndication is silently skipped.
X_API_KEY=
X_API_KEY_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

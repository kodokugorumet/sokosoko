# ===== Site =====
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ===== Analytics & Search Console (both optional) =====
# Google Analytics 4 measurement ID (G-XXXXXXXXXX). When unset, the GA
# script tag is omitted entirely.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Google Search Console verification token from the meta-tag method.
# Paste only the value of `content="..."` (no quotes, no surrounding tag).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ===== Sanity (https://sanity.io) =====
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01
# Read token (Viewer). Required only for draft/preview.
SANITY_API_READ_TOKEN=
# Webhook secret shared with Sanity -> GROQ webhook
SANITY_REVALIDATE_SECRET=

# ===== SNS auto-sync (all optional; fill per platform) =====
# X (Twitter) — Free tier: 1,500 posts/month
X_API_KEY=
X_API_KEY_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Bluesky
BLUESKY_IDENTIFIER=
BLUESKY_APP_PASSWORD=

# Instagram Graph API (requires FB Page + IG Business account)
IG_USER_ID=
IG_ACCESS_TOKEN=

# LINE Messaging API (LINE Notify EOL 2025-03-31)
LINE_CHANNEL_ACCESS_TOKEN=
LINE_TARGET_ID=
